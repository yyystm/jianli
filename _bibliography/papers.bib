@article{yang2026gait,
  abbr       = {二审},
  title      = {3D-Printed Mechanical Filtering Shoes for Hybrid Self-Supervised Gait Analysis},
  author     = {Yuyao Yang and Minglang Hu and Xinrong Tan and Songhan Sun and Wenbin Wang and Jiquan Yang and Jianping Shi},
  journal    = {IEEE Sensors Journal（二审阶段）},
  year       = {2026},
  abstract   = {Wearable inertial measurement units (IMUs) provide a cost-effective approach for gait analysis. However, signal quality is often compromised by wear-induced misalignment and dynamic motion artifacts, while traditional algorithms struggle to balance estimation accuracy with real-time performance. To address these challenges, this article proposes a monolithically integrated 3D-printed sensing shoe system combined with a hybrid computational framework. A gyroid lattice structure in the midsole acts as a mechanical low-pass filter, attenuating the high-frequency noise common in strap-based sensors. Complementing this hardware, we propose a two-stage hybrid algorithm that combines a physics-based Zero Velocity Update (ZUPT) model with a self-supervised residual network. This architecture leverages general gait-related representations pre-trained on unlabeled data, followed by a few-shot personalized calibration stage. By freezing the pre-trained encoder, the framework helps reduce overfitting on limited individual data and enables low-latency estimation on mobile platforms. Furthermore, the extracted gait parameters enable Symmetry Index (SI) calculations for customized 3D-printing design. Experimental results demonstrate that the embedded design significantly enhances inter-stride signal consistency, improving the Pearson correlation coefficient (PCC) from 0.848 to 0.913. The proposed personalized method reduces the mean absolute error (MAE) of step length to 2.29 cm and constrains the temporal errors for the stance and swing phases to 21.30 ms and 21.80 ms, respectively. Ultimately, this work presents a low-cost, high-fidelity proof-of-concept platform for real-time gait monitoring and personalized footwear-design feedback.},
  abstract_zh = {可穿戴惯性测量单元（IMU）为步态分析提供了一种低成本方案。然而，穿戴造成的安装偏差和动态运动伪影常常削弱信号质量，而传统算法也难以在估计精度与实时性能之间取得平衡。针对这些问题，本文提出了一种单体集成的 3D 打印传感鞋系统，并结合混合计算框架。中底中的 gyroid 晶格结构可作为机械低通滤波器，衰减绑带式传感器中常见的高频噪声。在硬件基础上，本文进一步提出一种两阶段混合算法，将基于物理模型的零速更新（ZUPT）方法与自监督残差网络结合。该架构先利用未标注数据预训练得到通用步态相关表征，再进行少样本个性化校准。通过冻结预训练编码器，该框架有助于减轻有限个体数据下的过拟合问题，并在移动平台上实现低延迟估计。此外，提取到的步态参数可用于计算对称性指数（SI），从而服务于定制化 3D 打印设计。实验结果表明，嵌入式设计显著提升了跨步信号一致性，使 Pearson 相关系数（PCC）从 0.848 提高到 0.913。所提出的个性化方法将步长平均绝对误差（MAE）降低至 2.29 cm，并将支撑相和摆动相的时间误差分别限制在 21.30 ms 和 21.80 ms。最终，本文提供了一个面向实时步态监测和个性化鞋类设计反馈的低成本、高保真概念验证平台。},
  keywords   = {3D printing, few-shot calibration, gait analysis, inertial measurement unit, mechanical filtering, self-supervised, sensor integration, zero velocity update},
  keywords_zh = {3D 打印, 少样本校准, 步态分析, 惯性测量单元, 机械滤波, 自监督, 传感器集成, 零速更新},
  corresponding_author = {施建平教授},
  corresponding_author_url = {https://eae.njnu.edu.cn/info/1051/1874.htm},
  preview    = {gait-shoe-graphical-abstract.png},
  website    = {https://eae.njnu.edu.cn/info/1051/1874.htm},
  website_label = {学院报道},
  selected   = {true}
}

@article{shan2025memristive_hopfield,
  abbr       = {二作},
  title      = {Dynamic Analysis, FPGA Implementation and Application of Memristive Hopfield Neural Network with Synapse Crosstalk},
  author     = {Minghao Shan and Yuyao Yang and Qianyi Tang and Xintong Hu and Fuhong Min},
  journal    = {Electronics, 14(12), 2464},
  volume     = {14},
  number     = {12},
  pages      = {2464},
  year       = {2025},
  doi        = {10.3390/electronics14122464},
  abstract   = {In a biological nervous system, neurons are connected to each other via synapses to transmit information. Synaptic crosstalk is the phenomenon of mutual interference or interaction of neighboring synapses between neurons. This phenomenon is prevalent in biological neural networks and has an important impact on the function and information processing of the neural system. In order to simulate and study this phenomenon, this paper proposes a memristor model based on hyperbolic tangent function for simulating the activation function of neurons, and constructs a three-neuron HNN model by coupling two memristors, which brings it close to the real behavior of biological neural networks, and provides a new tool for studying complex neural dynamics. The intricate nonlinear dynamics of the MHNN are examined using techniques like Lyapunov exponent analysis and bifurcation diagrams. The viability of the MHNN is confirmed through both analog circuit simulation and FPGA implementation. Moreover, an image encryption approach based on the chaotic system and a dynamic key generation mechanism are presented, highlighting the potential of the MHNN for real-world applications. The histogram shows that the encryption algorithm is effective in destroying the features of the original image. According to the sensitivity analysis, the bit change rate of the key is close to 50% when small perturbations are applied to each of the three parameters of the system, indicating that the system is highly resistant to differential attacks. The findings indicate that the MHNN displays a wide range of dynamical behaviors and high sensitivity to initial conditions, making it well-suited for applications in neuromorphic computing and information security.},
  abstract_zh = {在生物神经系统中，神经元之间通过突触连接传递信息。突触串扰是指神经元相邻突触之间的相互干扰或相互作用，这一现象广泛存在于生物神经网络中，并对神经系统功能和信息处理产生重要影响。为模拟并研究该现象，本文提出一种基于双曲正切函数的忆阻器模型，用于模拟神经元激活函数，并通过耦合两个忆阻器构建三神经元 HNN 模型，使其更接近生物神经网络的真实行为，为复杂神经动力学研究提供新的工具。本文利用 Lyapunov 指数分析和分岔图等方法研究了 MHNN 的复杂非线性动力学特性，并通过模拟电路仿真和 FPGA 实现验证了 MHNN 的可行性。此外，本文提出一种基于混沌系统和动态密钥生成机制的图像加密方法，展示了 MHNN 在实际应用中的潜力。直方图结果表明，该加密算法能够有效破坏原始图像特征；敏感性分析显示，当系统三个参数受到微小扰动时，密钥比特变化率接近 50%，说明系统对差分攻击具有较强抵抗能力。研究结果表明，该 MHNN 具有丰富的动力学行为和对初始条件的高敏感性，适用于类脑计算和信息安全等应用。},
  keywords   = {memristive Hopfield neural network, synaptic crosstalk, dynamic analysis, FPGA implementation, image encryption},
  keywords_zh = {忆阻 Hopfield 神经网络, 突触串扰, 动力学分析, FPGA 实现, 图像加密},
  corresponding_author = {闵富红教授},
  corresponding_author_url = {https://eae.njnu.edu.cn/info/1051/1866.htm},
  preview    = {memristive-hopfield-study-structure.png},
  selected   = {true}
}
